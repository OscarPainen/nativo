# ─────────────────────────────────────────────────────────────
# Configuración de Firebase (Consola → Configuración del proyecto →
# Tus apps → SDK de configuración). Copia este archivo como .env y
# rellena con tus valores. El archivo .env NUNCA se versiona.
# ─────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Identificador del tenant (barbería) que sirve esta instancia.
VITE_TENANT_ID=your_tenant_id

# ─────────────────────────────────────────────────────────────
# Integración Google Calendar (Apps Script). Opcional.
# La URL puede configurarse por tenant desde /admin/settings; estas son
# solo valores por defecto/fallback. El TOKEN es un secreto compartido con
# el Apps Script para validar el origen de las peticiones.
# NOTA: al ir en el bundle del cliente, el TOKEN no es 100% secreto; su rol
# es disuadir el abuso casual junto con la URL (que sí es difícil de adivinar).
# ─────────────────────────────────────────────────────────────
VITE_CALENDAR_WEBHOOK_URL=https://script.google.com/macros/s/XXXXXXXX/exec
VITE_CALENDAR_WEBHOOK_TOKEN=un_token_largo_y_aleatorio
