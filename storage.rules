rules_version = '2';

// ════════════════════════════════════════════════════════════════
// Reglas de Cloud Storage — DEFENSA EN PROFUNDIDAD.
//
// NOTA: esta app NO usa Storage actualmente (los comprobantes viven en
// Firestore y los logos como data-URI/URL). Este archivo NO está enlazado
// en firebase.json para no exigir Storage (plan de pago). Despliégalo con
//   firebase deploy --only storage
// solo si habilitas Storage en el futuro.
//
// Postura: todo denegado por defecto; rutas explícitas con límites de
// tamaño y tipo; sin listados de directorios.
// ════════════════════════════════════════════════════════════════
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin(tid) {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/tenants/$(tid)/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/tenants/$(tid)/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isImageUnder(maxBytes) {
      return request.resource.size < maxBytes
        && request.resource.contentType in ['image/jpeg', 'image/png', 'image/webp'];
    }

    // ── Comprobantes de pago: sube cualquier cliente autenticado; lee solo
    //    el admin del tenant. Máx 5 MB, solo imágenes. ──
    match /tenants/{tid}/comprobantes/{bookingId} {
      allow read: if isAdmin(tid);
      allow write: if isSignedIn() && isImageUnder(5 * 1024 * 1024);
    }

    // ── Logo del tenant: lectura pública; suben solo admins. Máx 2 MB. ──
    match /tenants/{tid}/logo {
      allow read: if true;
      allow write: if isAdmin(tid) && isImageUnder(2 * 1024 * 1024);
    }

    // ── Todo lo demás denegado (incluye listados de directorios) ──
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
